<Window x:Class="OpenStudio.App.PillWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ShowActivated="False"
        ResizeMode="NoResize" SizeToContent="WidthAndHeight">
    <Border Background="#E60B0D12" CornerRadius="22" Padding="16,10"
            BorderBrush="#33FFFFFF" BorderThickness="1"
            MouseLeftButtonDown="OnDrag">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Ellipse Width="10" Height="10" Fill="#EF4444" VerticalAlignment="Center" x:Name="RecDot" />
            <TextBlock x:Name="TimeText" Text="0:00" Foreground="#F8FAFC" FontSize="15"
                       FontFamily="Consolas" Margin="10,0,14,0" VerticalAlignment="Center" />
            <Button x:Name="PauseButton" Click="OnPause" Cursor="Hand" Margin="0,0,8,0"
                    Background="#1F2937" Foreground="#E5E7EB" BorderThickness="0"
                    Padding="12,4" FontSize="13">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                ❚❚
            </Button>
            <Button x:Name="StopButton" Click="OnStop" Cursor="Hand"
                    Background="#EF4444" Foreground="White" BorderThickness="0"
                    Padding="12,4" FontSize="13" FontWeight="SemiBold">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                Stop
            </Button>
            <Button x:Name="CancelButton" Click="OnCancel" Cursor="Hand" Margin="8,0,0,0"
                    Background="#1F2937" Foreground="#9CA3AF" BorderThickness="0"
                    Padding="12,4" FontSize="13">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                Discard
            </Button>
        </StackPanel>
    </Border>
</Window>
